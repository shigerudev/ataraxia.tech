# URL base de la API. Vacío = rutas relativas (/api/...), resueltas por el
# proxy de Vite (dev) o nginx (Docker).
VITE_API_URL=

# Supabase (obtén estos valores en el panel del proyecto)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ElevenLabs Agents (modo de voz del chat). Identificador de un agente PÚBLICO;
# es visible en el cliente, no es un secreto. Vacío = el modo de voz opera en
# demostración (el orbe reacciona al micrófono, sin conversación real).
# NUNCA colocar aquí la API key (xi-api-key). Para agentes privados, el backend
# deberá generar una signed URL (ver src/features/voice/model/useAgentVoice.ts).
VITE_ELEVENLABS_AGENT_ID=

# Agente PÚBLICO para la SALA de acompañamiento INDIVIDUAL (distinto del chat).
# Vacío = usa el agente del chat / modo demostración.
VITE_ELEVENLABS_AGENT_ID_INDIVIDUAL=

# Agente PÚBLICO que facilita la sala GRUPAL en vivo. El participante anfitrión
# (menor peerId) lo conecta y puentea su audio a toda la malla. Vacío = la sala
# grupal opera solo humano-a-humano. El agente debe emitir audio PCM (formato
# por defecto del WebSocket de ElevenLabs Agents).
VITE_ELEVENLABS_AGENT_ID_GROUP=

# Servidor TURN opcional para redes restrictivas (NAT simétrico). Sin TURN,
# algunos pares no logran conectarse; solo STUN público por defecto.
# Ejemplo: VITE_TURN_URL=turn:turn.midominio.com:3478
VITE_TURN_URL=
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=
